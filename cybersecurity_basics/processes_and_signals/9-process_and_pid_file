#!/usr/bin/env bash
# This script displays messages and manages a PID file with signal handling

# Create PID file
echo $$ > /tmp/myscript.pid

# Handle SIGINT (Ctrl+C)
trap 'echo "Y U no love me?!"' SIGINT

# Handle SIGTERM: display message then cleanup
trap 'echo "I hate the kill command"; rm -f /tmp/myscript.pid; exit 0' SIGTERM

# Handle SIGQUIT: cleanup only
trap 'rm -f /tmp/myscript.pid; exit 0' SIGQUIT

# Infinite loop
while true; do
    echo "To infinity and beyond"
    sleep 1
done
